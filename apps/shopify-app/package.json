{
  "name": "shopify-app",
  "version": "0.0.1",
  "private": true,
  "description": "Flintmere Shopify app — embedded catalog-readiness scoring + auto-fix engine at app.flintmere.com.",
  "type": "module",
  "scripts": {
    "dev": "shopify app dev",
    "build": "remix vite:build",
    "start": "remix-serve ./build/server/index.js",
    "lint": "eslint app",
