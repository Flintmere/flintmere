// Flintmere Shopify app database schema.
// Canonical per `projects/flintmere/ARCHITECTURE.md` §Database schema.
// This schema owns the `app_*` namespace; scanner owns `scanner_*` in its own schema.

generator client {
  provider      = "prisma-client-js"
  // Per-app output so the scanner's generated client and the shopify-app's
  // can coexist in pnpm's hoisted node_modules. Without `output`, both apps
  // race over the same `.prisma/client/` location and only the most recently
  // generated schema is type-visible.
  output        = "../app/generated/prisma"
  // `linux-musl-openssl-3.0.x` is the runtime target (node:22-alpine uses musl).
  // `native` covers the build host. Both must be present or PrismaClient throws
  // at first query with `Failed to load query engine`.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Shopify OAuth session store (required by @shopify/shopify-app-session-storage-prisma) ----

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// ---- Shops (our canonical record, encrypted token) ----

model Shop {
  shopDomain             String    @id @map("shop_domain")
  encryptedAccessToken   String    @map("encrypted_access_token")
  scopes                 String
  planTier               String    @default("free") @map("plan_tier")
  installedAt            DateTime  @default(now()) @map("installed_at")
  uninstalledAt          DateTime? @map("uninstalled_at")
  lastSyncAt             DateTime? @map("last_sync_at")
  lastScoreAt            DateTime? @map("last_score_at")
  lastScoreComposite     Int?      @map("last_score_composite")
  countryCode            String?   @map("country_code")
  primaryDomain          String?   @map("primary_domain")
  // Merchant-controlled settings (Settings page). Defaults preserve current
  // behaviour: no notifications, no auto-apply. Email is opt-in for sends.
  notificationsEmail     String?   @map("notifications_email")
  weeklyDigestEnabled    Boolean   @default(false) @map("weekly_digest_enabled")
  driftAlertsEnabled     Boolean   @default(false) @map("drift_alerts_enabled")
  autoApplyTier1Enabled  Boolean   @default(false) @map("auto_apply_tier1_enabled")
  // Set when APP_UNINSTALLED enqueues a 30-day data-purge job. Visible to
  // operators to confirm scheduled erasure ahead of the deadline. Cleared
  // on reinstall.
  purgeScheduledAt       DateTime? @map("purge_scheduled_at")
  purgeCompletedAt       DateTime? @map("purge_completed_at")

  products  Product[]
  scores    Score[]
  fixes     Fix[]
  webhooks  WebhookEvent[]

  @@index([planTier])
  @@index([installedAt])
  @@map("app_shops")
}

// ---- Catalog snapshot (populated by bulk sync) ----

model Product {
  id               String    @id @default(cuid())
  shopDomain       String    @map("shop_domain")
  shop             Shop      @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  shopifyProductId String    @map("shopify_product_id")
  handle           String
  title            String
  vendor           String?
  productType      String?   @map("product_type")
  status           String
  publishedAt      DateTime? @map("published_at")
  rawPayload       Json      @map("raw_payload")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  variants         Variant[]

  @@unique([shopDomain, shopifyProductId])
  @@index([shopDomain])
  @@map("app_products")
}

model Variant {
  id                String  @id @default(cuid())
  productId         String  @map("product_id")
  product           Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shopifyVariantId  String  @map("shopify_variant_id")
  sku               String?
  barcode           String?
  price             String
  inventoryQuantity Int?    @map("inventory_quantity")
  rawPayload        Json    @map("raw_payload")

  @@unique([productId, shopifyVariantId])
  @@map("app_variants")
}

// ---- Scoring + issues ----

model Score {
  id                 String   @id @default(cuid())
  shopDomain         String   @map("shop_domain")
  shop               Shop     @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  scoredAt           DateTime @default(now()) @map("scored_at")
  composite          Int
  grade              String
  gtinlessCeiling    Int      @map("gtinless_ceiling")
  pillars            Json
  productCount       Int      @map("product_count")
  variantCount       Int      @map("variant_count")

  issues Issue[]

  @@index([shopDomain])
  @@index([scoredAt])
  @@map("app_scores")
}

model Issue {
  id                  String   @id @default(cuid())
  scoreId             String   @map("score_id")
  score               Score    @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  pillar              String
  code                String
  severity            String
  title               String
  description         String
  affectedCount       Int      @map("affected_count")
  affectedProductIds  String[] @map("affected_product_ids")
  revenueImpactScore  Int      @map("revenue_impact_score")

  @@index([scoreId])
  @@index([code])
  @@map("app_issues")
}

// ---- Fix engine ----

model Fix {
  id           String    @id @default(cuid())
  shopDomain   String    @map("shop_domain")
  shop         Shop      @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  tier         Int
  status       String
  fixType      String    @map("fix_type")
  confidence   Float?
  productCount Int       @map("product_count")
  beforeState  Json      @map("before_state")
  afterState   Json      @map("after_state")
  appliedAt    DateTime  @default(now()) @map("applied_at")
  revertableUntil DateTime @map("revertable_until")
  revertedAt   DateTime? @map("reverted_at")

  @@index([shopDomain])
  @@index([revertableUntil])
  @@map("app_fixes")
}

// ---- Webhooks (idempotency) ----

model WebhookEvent {
  id             String   @id
  shopifyEventId String   @unique @map("shopify_event_id")
  shopDomain     String   @map("shop_domain")
  shop           Shop     @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  topic          String
  receivedAt     DateTime @default(now()) @map("received_at")
  processedAt    DateTime? @map("processed_at")
  payload        Json?

  @@index([shopDomain])
  @@index([topic])
  @@index([receivedAt])
  @@map("app_webhook_events")
}

// ---- GDPR audit trail ----
// Append-only record of every GDPR-bearing webhook receipt and the
// downstream durable jobs we scheduled in response. Operator queries this
// to prove the 30-day DSAR / redact response window was met. Never
// overwritten — `respondedAt` is set when the operator marks the case
// closed, but the row stays.

model GdprEvent {
  id              String    @id @default(cuid())
  shopDomain      String    @map("shop_domain")
  topic           String    // CUSTOMERS_DATA_REQUEST | CUSTOMERS_REDACT | SHOP_REDACT | APP_UNINSTALLED
  shopifyEventId  String?   @map("shopify_event_id")
  payload         Json
  receivedAt      DateTime  @default(now()) @map("received_at")
  deadlineAt      DateTime? @map("deadline_at")     // 30 days from receipt for DSAR + redact
  jobId           String?   @map("job_id")          // BullMQ job id of the scheduled action
  respondedAt     DateTime? @map("responded_at")    // operator marks closed
  notes           String?

  @@index([shopDomain])
  @@index([topic])
  @@index([deadlineAt])
  @@index([receivedAt])
  @@map("app_gdpr_events")
}

// ---- Channel Health (AI-attribution layer) ----

model ChannelHealth {
  id                     String   @id @default(cuid())
  shopDomain             String   @map("shop_domain")
  date                   DateTime
  aiClicks               Int      @default(0) @map("ai_clicks")
  aiOrders               Int      @default(0) @map("ai_orders")
  aiRevenuePence         Int      @default(0) @map("ai_revenue_pence")
  googleShoppingApprovals Int     @default(0) @map("google_shopping_approvals")
  aiOverviewsCitations   Int      @default(0) @map("ai_overviews_citations")

  @@unique([shopDomain, date])
  @@index([date])
  @@map("app_channel_health")
}
