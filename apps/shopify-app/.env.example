# Flintmere Shopify app — environment template
# Copy to .env.local for development. Production values live in Coolify.

# ---- Shopify ----
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_APP_URL="https://app.flintmere.com"
SHOPIFY_SCOPES="read_products,write_products,read_product_listings,write_metaobject_definitions,write_metaobjects"

# ---- Database ----
DATABASE_URL="postgresql://flintmere:flintmere_dev@localhost:5432/flintmere_dev?schema=app"

# ---- Token encryption (32 bytes base64) ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SHOPIFY_TOKEN_ENCRYPTION_KEY=""

# ---- Queue (Coolify-provisioned in prod) ----
REDIS_URL="redis://localhost:6379"

# ---- LLM ----
# Primary: Vertex AI Gemini (EU-pinned). See decisions/0005 + 0006.
LLM_PRIMARY_PROVIDER="vertex"
LLM_PRIMARY_MODEL="gemini-2.5-flash"
LLM_HARDCASE_MODEL="gemini-2.5-pro"
LLM_PRIMARY_REGION="europe-west1"
GOOGLE_CLOUD_PROJECT=""
GOOGLE_APPLICATION_CREDENTIALS="/path/to/vertex-service-account.json"

# Fallback: OpenAI Platform (privacy-by-minimization). See decisions/0007.
# Project-scoped key only (sk-proj-…); user keys rejected at construction.
LLM_FALLBACK_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_PROJECT_ID=""
OPENAI_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL=""  # optional override (reserve for future EU-pinned routing)

# ---- Billing ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ---- Email + observability ----
RESEND_API_KEY=""
SENTRY_DSN=""
POSTHOG_KEY=""
POSTHOG_HOST="http://localhost:8000"
