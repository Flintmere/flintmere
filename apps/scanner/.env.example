# Flintmere scanner — environment template
# Copy to .env.local for development. Production values live in Coolify.

# ---- Required ----

# Postgres connection (Coolify-provisioned in prod; docker-compose local in dev)
DATABASE_URL="postgresql://flintmere:flintmere_dev@localhost:5432/flintmere_dev?schema=scanner"

# Public base URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- LLM (used by the app, not scanner MVP; set for future compatibility) ----

# LLM_PRIMARY_PROVIDER="vertex"
# LLM_PRIMARY_MODEL="gemini-2.5-flash"
# LLM_PRIMARY_REGION="europe-west1"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# ---- Email (scanner full-report delivery) ----

# Resend API key (resend.com). Create a sending domain; point DNS (SPF/DKIM/DMARC).
RESEND_API_KEY=""
RESEND_FROM_ADDRESS="Flintmere <hello@flintmere.com>"
RESEND_REPLY_TO="hello@flintmere.com"

# HMAC secret for signed unsubscribe tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
UNSUBSCRIBE_SECRET=""

# Salt for hashing IPs (one-way; kept as rate-limit key without storing raw IP)
IP_HASH_SALT="flintmere-default-salt-change-me"

# ---- Stripe (concierge audit £97 one-offs) ----

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_CONCIERGE_PRICE_ID=""

# Calendly link for concierge kickoff call
CALENDLY_CONCIERGE_URL="https://calendly.com/flintmere/concierge-audit"

# ---- Observability (optional in dev) ----

# Sentry error tracking (EU region — sentry.io de-region account).
# Same DSN used both server- and client-side. The DSN is a public project
# write-key by Sentry's design; not a secret. Mark Available at Buildtime
# AND Available at Runtime in Coolify.
# NEXT_PUBLIC_SENTRY_DSN="https://<key>@o<id>.ingest.de.sentry.io/<project>"
#
# Optional — for source-map upload (better stack traces). Generate in
# Sentry → Settings → Auth Tokens. Keep secret; mark Buildtime only.
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG="flintmere"
# SENTRY_PROJECT="flintmere-scanner"
#
# Sentry self-test gate. Set to "true" temporarily, redeploy, GET
# /api/_sentry-test to fire a verification error, then unset.
# SENTRY_TEST_ENABLED="false"
# POSTHOG_KEY=""
# POSTHOG_HOST="http://localhost:8000"

# ---- Rate limiting ----

# Redis (Coolify-provisioned in prod)
# REDIS_URL="redis://localhost:6379"
