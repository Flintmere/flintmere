{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(git push*origin main*)",
      "Bash(git push*--force*)",
      "Bash(git push*-f*)",
      "Bash(pnpm run deploy*)",
      "Bash(pnpm run migrate*)",
      "Bash(pnpm db:push*)",
      "Bash(vercel*)",
      "Bash(stripe*)",
      "Bash(psql*)",
      "Bash(drizzle-kit push*)",
      "Bash(rm -rf*)"
    ]
  }
}
